---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'Iris Web — Website Design & Development',
  description = 'Iris Web designs and develops websites, landing pages, e-shops, and brand identities for clients who appreciate quality. Based in Kyiv, Ukraine.',
  canonical = Astro.url.href,
  image = '/og-image.jpg',
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://iris-web.studio';
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Base URL prefix — used for favicon and other public-folder assets
// when the site is served from a sub-path (e.g. /iris-web.studio/).
const baseRaw = import.meta.env.BASE_URL ?? '/';
const base = baseRaw.endsWith('/') ? baseRaw : baseRaw + '/';

// GTM / GA — set these in .env (PUBLIC_GTM_ID, PUBLIC_GA_ID)
const GTM_ID = import.meta.env.PUBLIC_GTM_ID;
const GA_ID = import.meta.env.PUBLIC_GA_ID;

// JSON-LD structured data
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Iris Web',
  url: siteUrl,
  logo: `${siteUrl}${base}logo.png`,
  description,
  email: '7vred7@gmail.com',
  telephone: '+380962082294',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Kyiv',
    addressCountry: 'UA',
  },
  sameAs: [],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Iris Web',
  url: siteUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Iris Web" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a14" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    <!-- Google Tag Manager (head) -->
    {GTM_ID && (
      <script is:inline set:html={`
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${GTM_ID}');
      `} />
    )}
    <!-- End GTM (head) -->

    <!-- Google Analytics 4 (only loads if no GTM, to avoid double-firing) -->
    {!GTM_ID && GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`} />
        <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${GA_ID}');
        `} />
      </>
    )}
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    {GTM_ID && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        />
      </noscript>
    )}
    <!-- End GTM (noscript) -->

    <slot />

    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
