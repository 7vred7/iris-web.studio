---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Menu from '../components/Menu.astro';
import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Stack from '../components/Stack.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Iris Web — Website Design & Development Studio | Kyiv, Ukraine"
  description="Iris Web designs and develops websites, landing pages, e-shops, and brand identities. We build with WordPress or Astro + open-source CMS, AI-first workflow, optimized for AI search. Based in Kyiv, Ukraine."
>
  <Header />
  <Menu />
  <main>
    <Hero />
    <Portfolio />
    <About />
    <Services />
    <Stack />
    <Contact />
  </main>
  <Footer />
</Layout>
