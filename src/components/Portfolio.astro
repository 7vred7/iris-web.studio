---
import '../styles/portfolio.css';
import { Image } from 'astro:assets';

// Imported as ES modules so Astro can process them at build time:
// auto-resize, convert to WebP, generate srcset, lazy-load.
import dreamwayImg from '../assets/portfolio/dreamway.jpg';
import globalcarsImg from '../assets/portfolio/globalcars.jpg';
import litaxImg from '../assets/portfolio/litax.jpg';
import hypnotherapyImg from '../assets/portfolio/hypnotherapy.jpg';

const projects = [
  {
    title: 'Dreamway to Korea',
    domain: 'dreamway-study.com',
    category: 'wordpress',
    palette: 'c', // violet
    href: 'https://dreamway-study.com/',
    description:
      'Educational agency for Korean university admissions — language courses, student visas, and full application support.',
    image: dreamwayImg,
  },
  {
    title: 'Global Cars Korea',
    domain: 'globalcarskorea.com',
    category: 'wordpress',
    palette: 'b', // blue
    href: 'https://globalcarskorea.com/',
    description:
      'Used car export from South Korea to Europe and worldwide — sourcing, inspection, and logistics handled end-to-end.',
    image: globalcarsImg,
  },
  {
    title: 'Long Island Tax Resolution',
    domain: 'longislandtaxresolution.com',
    category: 'wordpress',
    palette: 'd', // emerald
    href: 'https://longislandtaxresolution.com/',
    description:
      'IRS tax resolution and representation firm serving clients across Long Island, New York.',
    image: litaxImg,
  },
  {
    title: 'Hypnotherapy — Design Directions',
    domain: '7vred7.github.io',
    category: 'astro',
    palette: 'a', // pink
    href: 'https://7vred7.github.io/hypnotherapy-demo/',
    description:
      'Three landing page design directions for a hypnotherapy practice. Built with Astro, deployed on GitHub Pages.',
    image: hypnotherapyImg,
  },
];

const stackLabel = {
  wordpress: 'WordPress',
  astro: 'Astro',
};
---

<section class="portfolio section" id="portfolio">
  <div class="container">
    <span class="section-eyebrow" data-reveal>our</span>
    <h2 class="section-title" data-reveal data-reveal-delay="100">Websites</h2>

    <div
      class="portfolio-filters"
      data-portfolio-filters
      data-reveal
      data-reveal-delay="200"
    >
      <button class="filter-btn is-active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="wordpress">WordPress</button>
      <button class="filter-btn" data-filter="astro">Astro</button>
    </div>

    <ul class="portfolio-grid" data-portfolio-grid>
      {projects.map((p, i) => (
        <li
          class="portfolio-item"
          data-category={p.category}
          style={`--i:${i}`}
          data-reveal
          data-reveal-delay={300 + i * 100}
        >
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="portfolio-card"
            data-palette={p.palette}
          >
            <div class="portfolio-tilt-inner">
              <div class="portfolio-thumb">
                <Image
                  src={p.image}
                  alt={p.title + ' — cover'}
                  widths={[400, 800, 1200]}
                  sizes="(min-width: 1100px) 540px, (min-width: 700px) 90vw, 100vw"
                  format="webp"
                  quality={80}
                  loading="lazy"
                  class="portfolio-thumb-img"
                />
                <div class="portfolio-thumb-overlay" aria-hidden="true"></div>
                <span class="portfolio-thumb-badge">{stackLabel[p.category]}</span>
                <span class="portfolio-thumb-domain">{p.domain}</span>
              </div>
              <div class="portfolio-info">
                <h3 class="portfolio-title">{p.title}</h3>
                <p class="portfolio-description">{p.description}</p>
                <span class="portfolio-link">
                  Visit site
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17L17 7"></path>
                    <path d="M7 7h10v10"></path>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
