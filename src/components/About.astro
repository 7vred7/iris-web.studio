---
import '../styles/about.css';
---

<section class="about section" id="about">
  <div class="container about-grid">
    <div class="about-content">
      <span class="section-eyebrow" data-reveal>about</span>
      <h2 class="about-title" data-reveal data-reveal-delay="100">A studio that builds with intention</h2>
      <p data-reveal data-reveal-delay="200">
        Our main activity is the development and design of websites, landing pages,
        and the creation of corporate identities and logos.
      </p>
      <p data-reveal data-reveal-delay="300">
        We specialize in building e-shops of any complexity. With our help, you'll
        receive a high-quality online resource — clear in purpose, fast in delivery,
        and beautiful in execution.
      </p>
      <p data-reveal data-reveal-delay="400">
        We understand exactly what a product should be and how to get it there.
        You'll get a unique, user-friendly, and effective website — and we support
        every project at every stage, long after launch.
      </p>
      <a href="#contact" class="btn btn-primary about-cta" data-reveal data-reveal-delay="500">
        Let's Work Together
      </a>
    </div>

    <div class="about-stats">
      <div class="stat" data-reveal data-reveal-delay="200">
        <span class="stat-number" data-count-to="7" data-count-suffix="+">0+</span>
        <span class="stat-label">Years in business</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="300">
        <span class="stat-number" data-count-to="50" data-count-suffix="+">0+</span>
        <span class="stat-label">Projects delivered</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="400">
        <span class="stat-number" data-count-to="100" data-count-suffix="%">0%</span>
        <span class="stat-label">Custom-built</span>
      </div>
      <div class="stat" data-reveal data-reveal-delay="500">
        <span class="stat-number">∞</span>
        <span class="stat-label">Post-launch support</span>
      </div>
    </div>
  </div>
</section>
