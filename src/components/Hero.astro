---
import '../styles/hero.css';
---

<section class="hero" id="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-orbs">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="hero-noise"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-logo-wrap" data-tilt>
      <span class="hero-logo" role="img" aria-label="Iris Web logo"></span>
    </div>

    <h1 class="hero-title" data-reveal data-reveal-delay="200">
      For those who appreciate <em>quality</em>
    </h1>

    <p class="hero-subtitle" data-reveal data-reveal-delay="350">
      Website design, development, and brand identity — crafted with care for clients
      who refuse to settle for ordinary.
    </p>

    <div class="hero-cta" data-reveal data-reveal-delay="500">
      <a href="#portfolio" class="btn btn-primary">See Our Work</a>
      <a href="#contact" class="btn btn-outline">Start a Project</a>
    </div>
  </div>

  <a href="#portfolio" class="hero-scroll" aria-label="Scroll to portfolio">
    <span class="hero-scroll-text">Scroll</span>
    <span class="hero-scroll-line"></span>
  </a>
</section>
